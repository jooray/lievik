# Environment Variables for Lievik
# Copy this file to .env and update the values

# Flask Configuration
FLASK_ENV=development
FLASK_HOST=127.0.0.1
FLASK_PORT=5000
FLASK_DEBUG=True
SECRET_KEY=your-secret-key-change-in-production

# Database Configuration
# For development (SQLite)
DATABASE_URL=sqlite:///lievik_dev.db

# For MySQL
# DATABASE_URL=mysql+pymysql://username:password@localhost/lievik

# For PostgreSQL
# DATABASE_URL=postgresql://username:password@localhost/lievik

# LLM API Keys (optional, can be configured per crew)
GEMINI_API_KEY=your-gemini-api-key
VENICE_API_KEY=your-venice-api-key
OPENAI_API_KEY=your-openai-api-key

# Nostr Configuration
NOSTR_PRIVATE_KEY=your-nostr-private-key

# Content Ingestion Settings
INGESTION_INTERVAL_HOURS=1
MAX_CONTENT_AGE_DAYS=30

# CrewAI Configuration
CREWAI_DISABLE_TELEMETRY=true
OTEL_SDK_DISABLED=true
