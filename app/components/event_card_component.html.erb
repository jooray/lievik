<div class="bg-white dark:bg-gray-800 rounded-lg shadow p-4 mb-4" id="<%= dom_id(channel_event) %>">
  <div class="flex justify-between items-start mb-2">
    <div class="flex items-center gap-2">
      <span class="px-2 py-1 rounded text-xs font-bold <%= relevance_color %>">
        <%= channel_event.relevance_score %>%
      </span>
      <span class="px-2 py-1 rounded text-xs font-medium <%= event_type_badge[:class] %>">
        <%= event_type_badge[:text] %>
      </span>
    </div>
    <div class="text-xs text-gray-500 dark:text-gray-400">
      <%= time_ago_in_words(event.published_at) %> ago
    </div>
  </div>

  <div class="mb-3">
    <p class="text-gray-600 dark:text-gray-300 text-sm">
      From: <strong><%= source.name || source.identifier.truncate(20) %></strong>
      <span class="text-gray-400 text-xs">(distance: <%= source.distance %>)</span>
    </p>
  </div>

  <div class="prose dark:prose-invert max-w-none mb-4 text-sm whitespace-pre-wrap text-gray-800 dark:text-gray-200"><%= render_nostr_content(event.content) %></div>

  <% if event.linked_contents.any? %>
    <div class="border-t dark:border-gray-700 pt-3 mt-3">
      <p class="text-xs text-gray-500 mb-2 font-medium">Linked content:</p>
      <% event.linked_contents.each do |link| %>
        <div class="text-xs bg-gray-50 dark:bg-gray-900 rounded p-2 mb-2">
          <% if link.title.present? %>
            <p class="font-medium mb-1"><%= link.title %></p>
          <% end %>
          <a href="<%= link.url %>" target="_blank" class="text-blue-600 dark:text-blue-400 hover:underline">
            <%= truncate(link.url, length: 50) %>
          </a>
        </div>
      <% end %>
    </div>
  <% end %>

  <div class="flex justify-between items-center mt-4 pt-3 border-t dark:border-gray-700">
    <div class="flex gap-4">
      <% if nostr_link %>
        <%= link_to "View on Nostr", nostr_link, target: "_blank", class: "text-xs text-purple-600 dark:text-purple-400 hover:underline" %>
      <% end %>
    </div>

    <div class="flex gap-2">
      <% if channel_event.used? %>
        <%= button_to "Mark unused", mark_unused_channel_event_path(channel_event.channel, channel_event), method: :post, class: "px-3 py-1 text-xs bg-gray-200 dark:bg-gray-700 hover:bg-gray-300 dark:hover:bg-gray-600 rounded transition-colors" %>
      <% else %>
        <%= button_to "Mark as used", mark_used_channel_event_path(channel_event.channel, channel_event), method: :post, class: "px-3 py-1 text-xs bg-purple-600 hover:bg-purple-700 text-white rounded transition-colors" %>
      <% end %>
    </div>
  </div>
</div>
