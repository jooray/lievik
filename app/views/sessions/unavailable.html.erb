<div class="max-w-md mx-auto mt-16 px-4">
  <div class="bg-white dark:bg-gray-800 rounded-xl shadow-lg p-8 text-center space-y-4">
    <div class="mx-auto flex h-12 w-12 items-center justify-center rounded-full bg-purple-100 dark:bg-purple-900/30">
      <svg class="h-6 w-6 text-purple-600 dark:text-purple-400" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/>
      </svg>
    </div>

    <h1 class="text-xl font-semibold text-gray-900 dark:text-gray-100"><%= @unavailable_title %></h1>
    <p class="text-sm text-gray-600 dark:text-gray-400"><%= @unavailable_message %></p>

    <%= link_to "Try again", nostr_login_path,
          data: { turbo: false },
          class: "inline-flex items-center justify-center px-4 py-2 rounded-lg bg-purple-600 hover:bg-purple-700 text-white text-sm font-medium" %>
  </div>
</div>
