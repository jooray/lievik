<div class="max-w-2xl mx-auto">
  <div class="mb-6">
    <h1 class="text-2xl font-bold text-gray-900 dark:text-white">Add Manual Event</h1>
    <p class="mt-1 text-sm text-gray-500 dark:text-gray-400">
      Manually enter content to be curated for your channels
    </p>
  </div>

  <%= form_with model: @event, url: manual_events_path, class: "space-y-6 bg-white dark:bg-gray-800 shadow rounded-lg p-6" do |form| %>
    <% if @event.errors.any? %>
      <div class="rounded-md bg-red-50 dark:bg-red-900/30 border border-red-200 dark:border-red-800 p-4">
        <div class="flex items-start gap-3">
          <svg class="h-5 w-5 flex-shrink-0 text-red-600 dark:text-red-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
          </svg>
          <div>
            <h2 class="text-sm font-medium text-red-800 dark:text-red-200">
              This event could not be saved
            </h2>
            <ul class="mt-1 list-disc list-inside text-sm text-red-700 dark:text-red-300">
              <% @event.errors.full_messages.each do |message| %>
                <li><%= message %></li>
              <% end %>
            </ul>
          </div>
        </div>
      </div>
    <% end %>

    <div>
      <%= form.label :content, class: "block text-sm font-medium text-gray-700 dark:text-gray-300" %>
      <%= form.text_area :content, rows: 8, required: true, class: "mt-1 block w-full rounded-md border-gray-300 dark:border-gray-600 dark:bg-gray-700 dark:text-white shadow-sm focus:border-purple-500 focus:ring-purple-500 sm:text-sm", placeholder: "Paste or type content here..." %>
    </div>

    <div class="flex items-center justify-end gap-3 pt-4 border-t border-gray-200 dark:border-gray-700">
      <%= link_to "Cancel", dashboard_path, class: "px-4 py-2 text-sm font-medium text-gray-700 dark:text-gray-300 hover:text-gray-500" %>
      <%= form.submit "Add Event", class: "inline-flex justify-center rounded-md border border-transparent bg-purple-600 py-2 px-4 text-sm font-medium text-white shadow-sm hover:bg-purple-700 focus:outline-none focus:ring-2 focus:ring-purple-500 focus:ring-offset-2 cursor-pointer" %>
    </div>
  <% end %>
</div>
