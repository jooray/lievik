<%= form_with model: source, class: "space-y-6 bg-white dark:bg-gray-800 shadow rounded-lg p-6", data: { controller: "source-form", source_form_source_type_value: source.source_type } do |form| %>
  <% if source.errors.any? %>
    <div class="rounded-md bg-red-50 dark:bg-red-900/20 p-4">
      <div class="flex">
        <div class="ml-3">
          <h3 class="text-sm font-medium text-red-800 dark:text-red-200">
            <%= pluralize(source.errors.count, "error") %> prevented this source from being saved:
          </h3>
          <div class="mt-2 text-sm text-red-700 dark:text-red-300">
            <ul class="list-disc pl-5 space-y-1">
              <% source.errors.full_messages.each do |message| %>
                <li><%= message %></li>
              <% end %>
            </ul>
          </div>
        </div>
      </div>
    </div>
  <% end %>

  <div>
    <%= form.label :source_type, "Source Type", class: "block text-sm font-medium text-gray-700 dark:text-gray-300" %>
    <%= form.select :source_type,
      [["Nostr Account", "nostr"], ["RSS Feed", "rss"]],
      {},
      class: "mt-1 block w-full rounded-md border-gray-300 dark:border-gray-600 dark:bg-gray-700 dark:text-white shadow-sm focus:border-purple-500 focus:ring-purple-500 sm:text-sm",
      data: { action: "change->source-form#typeChanged", source_form_target: "typeSelect" }
    %>
  </div>

  <div>
    <%= form.label :identifier, class: "block text-sm font-medium text-gray-700 dark:text-gray-300" do %>
      <span data-source-form-target="identifierLabel">
        <%= source.nostr? ? "Nostr Public Key (npub)" : "Feed URL" %>
      </span>
    <% end %>
    <%= form.text_field :identifier,
      class: "mt-1 block w-full rounded-md border-gray-300 dark:border-gray-600 dark:bg-gray-700 dark:text-white shadow-sm focus:border-purple-500 focus:ring-purple-500 sm:text-sm",
      placeholder: source.nostr? ? "npub1..." : "https://example.com/feed.xml",
      data: { source_form_target: "identifierInput" }
    %>
    <p class="mt-1 text-xs text-gray-500 dark:text-gray-400" data-source-form-target="identifierHint">
      <%= source.nostr? ? "Enter the npub or hex public key of the account" : "Enter the URL of the RSS or Atom feed" %>
    </p>
  </div>

  <div>
    <%= form.label :name, class: "block text-sm font-medium text-gray-700 dark:text-gray-300" %>
    <%= form.text_field :name, class: "mt-1 block w-full rounded-md border-gray-300 dark:border-gray-600 dark:bg-gray-700 dark:text-white shadow-sm focus:border-purple-500 focus:ring-purple-500 sm:text-sm", placeholder: "Friendly name (optional)" %>
    <p class="mt-1 text-xs text-gray-500 dark:text-gray-400">Will be auto-populated from profile/feed if left blank</p>
  </div>

  <div>
    <%= form.label :description, class: "block text-sm font-medium text-gray-700 dark:text-gray-300" %>
    <%= form.text_area :description, rows: 3, class: "mt-1 block w-full rounded-md border-gray-300 dark:border-gray-600 dark:bg-gray-700 dark:text-white shadow-sm focus:border-purple-500 focus:ring-purple-500 sm:text-sm", placeholder: "Describe what kind of content this source produces..." %>
  </div>

  <div>
    <%= form.label :distance, "Relevance Distance (0-10)", class: "block text-sm font-medium text-gray-700 dark:text-gray-300" %>
    <%= form.number_field :distance, min: 0, max: 10, class: "mt-1 block w-32 rounded-md border-gray-300 dark:border-gray-600 dark:bg-gray-700 dark:text-white shadow-sm focus:border-purple-500 focus:ring-purple-500 sm:text-sm" %>
    <p class="mt-1 text-xs text-gray-500 dark:text-gray-400">0 = Your own content (most relevant), 10 = Distant contact (least relevant)</p>
  </div>

  <div class="border-t border-gray-200 dark:border-gray-700 pt-6" data-source-form-target="nostrSettings">
    <h3 class="text-sm font-medium text-gray-900 dark:text-white mb-4">Import Settings</h3>

    <div class="space-y-4">
      <div class="flex items-center">
        <%= form.check_box :settings_include_replies, { class: "h-4 w-4 rounded border-gray-300 text-purple-600 focus:ring-purple-500" }, true, false %>
        <%= form.label :settings_include_replies, "Include replies", class: "ml-2 block text-sm text-gray-700 dark:text-gray-300" %>
      </div>

      <div class="flex items-center">
        <%= form.check_box :settings_include_reposts, { class: "h-4 w-4 rounded border-gray-300 text-purple-600 focus:ring-purple-500" }, true, false %>
        <%= form.label :settings_include_reposts, "Include reposts", class: "ml-2 block text-sm text-gray-700 dark:text-gray-300" %>
      </div>

      <div>
        <%= form.label :settings_import_days, "Import days", class: "block text-sm font-medium text-gray-700 dark:text-gray-300" %>
        <%= form.number_field :settings_import_days, min: 1, max: 3650, class: "mt-1 block w-32 rounded-md border-gray-300 dark:border-gray-600 dark:bg-gray-700 dark:text-white shadow-sm focus:border-purple-500 focus:ring-purple-500 sm:text-sm" %>
        <p class="mt-1 text-xs text-gray-500 dark:text-gray-400">How many days of history to import (max 10 years)</p>
      </div>
    </div>
  </div>

  <div class="flex items-center justify-end gap-3 pt-4 border-t border-gray-200 dark:border-gray-700">
    <%= link_to "Cancel", sources_path, class: "px-4 py-2 text-sm font-medium text-gray-700 dark:text-gray-300 hover:text-gray-500" %>
    <%= form.submit source.persisted? ? "Update Source" : "Add Source", class: "inline-flex justify-center rounded-md border border-transparent bg-purple-600 py-2 px-4 text-sm font-medium text-white shadow-sm hover:bg-purple-700 focus:outline-none focus:ring-2 focus:ring-purple-500 focus:ring-offset-2 cursor-pointer" %>
  </div>
<% end %>
