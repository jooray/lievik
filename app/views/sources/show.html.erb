<div class="space-y-6">
  <div class="flex items-center gap-4">
    <%= link_to sources_path, class: "text-gray-500 hover:text-gray-700 dark:text-gray-400 dark:hover:text-gray-200" do %>
      <svg class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18"/>
      </svg>
    <% end %>
    <div class="flex-1 min-w-0">
      <h1 class="text-2xl font-bold text-gray-900 dark:text-white truncate">
        <%= @source.name || @source.identifier.truncate(40) %>
      </h1>
      <p class="mt-1 text-sm text-gray-500 dark:text-gray-400">
        <%= @source.nostr? ? "Nostr" : (@source.rss? ? "RSS" : "Manual") %> source &middot; Distance <%= @source.distance %>
      </p>
    </div>
    <div class="flex items-center gap-2 flex-shrink-0">
      <%= button_to refresh_source_path(@source), method: :post, class: "p-2 text-gray-400 hover:text-gray-500 dark:hover:text-gray-300" do %>
        <svg class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15"/>
        </svg>
      <% end %>
      <%= link_to edit_source_path(@source), class: "p-2 text-gray-400 hover:text-gray-500 dark:hover:text-gray-300" do %>
        <svg class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"/>
        </svg>
      <% end %>
    </div>
  </div>

  <div class="bg-white dark:bg-gray-800 shadow rounded-lg p-4">
    <p class="text-sm text-gray-500 dark:text-gray-400 truncate" title="<%= @source.identifier %>">
      <%= @source.identifier %>
    </p>
    <% if @source.description.present? %>
      <p class="mt-2 text-sm text-gray-600 dark:text-gray-300"><%= @source.description %></p>
    <% end %>
  </div>

  <div class="bg-white dark:bg-gray-800 shadow rounded-lg overflow-hidden">
    <div class="px-4 py-5 sm:px-6 border-b border-gray-200 dark:border-gray-700">
      <h2 class="text-lg font-medium text-gray-900 dark:text-white">Events</h2>
    </div>

    <% if @events.any? %>
      <ul class="divide-y divide-gray-200 dark:divide-gray-700">
        <% @events.each do |event| %>
          <li class="px-4 py-4 sm:px-6 hover:bg-gray-50 dark:hover:bg-gray-700">
            <p class="text-sm text-gray-900 dark:text-gray-100 whitespace-pre-wrap">
              <%= render_nostr_content(truncate(event.content, length: 300)) %>
            </p>
            <div class="mt-2 flex items-center gap-3 text-xs text-gray-500 dark:text-gray-400">
              <span><%= time_ago_in_words(event.published_at) %> ago</span>
              <span>&middot;</span>
              <span class="inline-flex items-center px-2 py-0.5 rounded-full text-xs font-medium <%= event.original? ? 'bg-blue-100 text-blue-800 dark:bg-blue-900 dark:text-blue-200' : 'bg-gray-100 text-gray-800 dark:bg-gray-700 dark:text-gray-200' %>">
                <%= event.event_type.capitalize %>
              </span>
              <span>&middot;</span>
              <%= link_to "View details", event_path(event), class: "text-purple-600 dark:text-purple-400 hover:underline" %>
            </div>
          </li>
        <% end %>
      </ul>
      <div class="px-4 py-3 bg-gray-50 dark:bg-gray-700 border-t border-gray-200 dark:border-gray-700">
        <%= paginate @events %>
      </div>
    <% else %>
      <div class="p-10 text-center">
        <p class="text-sm text-gray-500 dark:text-gray-400">No events from this source yet.</p>
      </div>
    <% end %>
  </div>
</div>
