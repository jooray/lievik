<div class="space-y-6">
  <div class="flex items-center justify-between">
    <div>
      <h1 class="text-2xl font-bold text-gray-900 dark:text-white">Sources</h1>
      <p class="mt-1 text-sm text-gray-500 dark:text-gray-400">
        Nostr accounts and RSS feeds to curate content from
      </p>
    </div>
    <div class="flex gap-3">
      <%= button_to refresh_all_sources_path, method: :post, class: "inline-flex items-center px-3 py-2 border border-gray-300 dark:border-gray-600 text-sm font-medium rounded-md text-gray-700 dark:text-gray-200 bg-white dark:bg-gray-800 hover:bg-gray-50 dark:hover:bg-gray-700" do %>
        <svg class="h-4 w-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15"/>
        </svg>
        Refresh All
      <% end %>
      <%= link_to new_source_path, class: "inline-flex items-center px-3 py-2 border border-transparent text-sm font-medium rounded-md shadow-sm text-white bg-purple-600 hover:bg-purple-700" do %>
        <svg class="h-4 w-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"/>
        </svg>
        Add Source
      <% end %>
    </div>
  </div>

  <% if @sources.empty? %>
    <div class="text-center py-12 bg-white dark:bg-gray-800 rounded-lg shadow">
      <svg class="mx-auto h-12 w-12 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10"/>
      </svg>
      <h3 class="mt-2 text-sm font-medium text-gray-900 dark:text-white">No sources</h3>
      <p class="mt-1 text-sm text-gray-500 dark:text-gray-400">Get started by adding a Nostr account to follow.</p>
      <div class="mt-6">
        <%= link_to new_source_path, class: "inline-flex items-center px-4 py-2 border border-transparent text-sm font-medium rounded-md shadow-sm text-white bg-purple-600 hover:bg-purple-700" do %>
          Add Source
        <% end %>
      </div>
    </div>
  <% else %>
    <div class="bg-white dark:bg-gray-800 shadow rounded-lg overflow-hidden">
      <ul class="divide-y divide-gray-200 dark:divide-gray-700">
        <% @sources.each do |source| %>
          <li class="px-4 py-4 sm:px-6 hover:bg-gray-50 dark:hover:bg-gray-700/50">
            <div class="flex items-center justify-between">
              <div class="flex-1 min-w-0">
                <div class="flex items-center gap-3">
                  <p class="text-sm font-medium text-gray-900 dark:text-white truncate">
                    <%= source.name || source.identifier.truncate(30) %>
                  </p>
                  <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium <%= source.nostr? ? 'bg-purple-100 text-purple-800 dark:bg-purple-900 dark:text-purple-200' : 'bg-orange-100 text-orange-800 dark:bg-orange-900 dark:text-orange-200' %>">
                    <%= source.nostr? ? 'Nostr' : 'RSS' %>
                  </span>
                  <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-gray-100 text-gray-800 dark:bg-gray-700 dark:text-gray-200">
                    Distance: <%= source.distance %>
                  </span>
                  <span class="text-xs text-gray-400">
                    <%= @event_counts.fetch(source.id, 0) %> events
                  </span>
                </div>
                <div class="mt-1 flex items-center gap-1">
                  <% if source.nostr? %>
                    <span class="text-sm text-gray-500 dark:text-gray-400 truncate cursor-pointer hover:text-purple-600 dark:hover:text-purple-400"
                          data-controller="clipboard"
                          data-clipboard-text-value="<%= source.identifier %>"
                          data-action="click->clipboard#copy"
                          title="Click to copy">
                      <%= source.identifier.truncate(50) %>
                    </span>
                    <a href="<%= current_user.profile_url(source.identifier) %>" target="_blank" rel="noopener noreferrer" title="View profile" class="text-gray-400 hover:text-purple-600 dark:hover:text-purple-400 flex-shrink-0">
                      <svg class="h-3.5 w-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"/>
                      </svg>
                    </a>
                  <% else %>
                    <span class="text-sm text-gray-500 dark:text-gray-400 truncate">
                      <%= source.identifier.truncate(50) %>
                    </span>
                  <% end %>
                </div>
                <% if source.description.present? %>
                  <p class="mt-1 text-xs text-gray-400 dark:text-gray-500 truncate">
                    <%= source.description.truncate(80) %>
                  </p>
                <% end %>
              </div>
              <div class="flex items-center gap-2">
                <%= button_to refresh_source_path(source), method: :post, class: "p-2 text-gray-400 hover:text-gray-500 dark:hover:text-gray-300" do %>
                  <svg class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15"/>
                  </svg>
                <% end %>
                <%= link_to edit_source_path(source), class: "p-2 text-gray-400 hover:text-gray-500 dark:hover:text-gray-300" do %>
                  <svg class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"/>
                  </svg>
                <% end %>
              </div>
            </div>
          </li>
        <% end %>
      </ul>
    </div>
  <% end %>
</div>
