<div class="max-w-2xl mx-auto">
  <div class="mb-6">
    <h1 class="text-2xl font-bold text-gray-900 dark:text-white">Edit Source</h1>
    <p class="mt-1 text-sm text-gray-500 dark:text-gray-400">
      <%= @source.name || @source.identifier.truncate(30) %>
    </p>
  </div>

  <%= render "form", source: @source %>

  <div class="mt-6 bg-red-50 dark:bg-red-900/20 rounded-lg p-4">
    <h3 class="text-sm font-medium text-red-800 dark:text-red-200">Danger Zone</h3>
    <p class="mt-1 text-sm text-red-700 dark:text-red-300">
      Deleting this source will also delete all its events.
    </p>
    <%= button_to source_path(@source), method: :delete, data: { turbo_confirm: "Delete this source? This will permanently delete all of its events too. This cannot be undone." }, class: "mt-3 inline-flex items-center px-3 py-2 border border-transparent text-sm font-medium rounded-md text-red-700 dark:text-red-200 bg-red-100 dark:bg-red-900/50 hover:bg-red-200 dark:hover:bg-red-900" do %>
      Delete Source
    <% end %>
  </div>
</div>
