<div id="generation-prompt-panel" class="bg-white dark:bg-gray-800 shadow rounded-lg" data-controller="inline-prompt-editor">
  <div class="px-4 py-3 border-b border-gray-200 dark:border-gray-700 flex items-center justify-between gap-3">
    <h2 class="text-lg font-medium text-gray-900 dark:text-white">Theme / Direction</h2>
    <button type="button" data-action="click->inline-prompt-editor#edit" class="text-sm font-medium text-purple-600 hover:text-purple-700 dark:text-purple-400 dark:hover:text-purple-300">
      <%= @channel_content.generation_prompt.present? ? "Edit" : "Add" %>
    </button>
  </div>
  <div class="p-4 space-y-3">
    <div data-inline-prompt-editor-target="display" class="<%= 'hidden' if @channel_content.generation_prompt.blank? %>">
      <p class="text-sm text-gray-600 dark:text-gray-400 italic whitespace-pre-wrap"><%= @channel_content.generation_prompt %></p>
    </div>

    <div data-inline-prompt-editor-target="display" class="<%= 'hidden' unless @channel_content.generation_prompt.blank? %>">
      <p class="text-sm text-gray-500 dark:text-gray-400">No theme or direction yet.</p>
    </div>

    <div data-inline-prompt-editor-target="form" class="hidden">
      <%= form_with model: @channel_content, url: channel_content_path(@channel, @channel_content), method: :patch, local: true, scope: :channel_content, class: "space-y-3" do |f| %>
        <div>
          <%= f.text_area :generation_prompt,
                          value: @channel_content.generation_prompt,
                          rows: 5,
                          data: { inline_prompt_editor_target: "textarea" },
                          class: "w-full rounded-md border-gray-300 dark:border-gray-600 dark:bg-gray-700 dark:text-white shadow-sm focus:border-purple-500 focus:ring-purple-500 sm:text-sm",
                          placeholder: "Add the angle, themes, or constraints you want the AI to follow..." %>
        </div>
        <div class="flex items-center gap-2">
          <%= f.submit "Save", class: "px-3 py-1.5 text-sm bg-purple-600 hover:bg-purple-700 text-white rounded-md" %>
          <button type="button" data-action="click->inline-prompt-editor#cancel" class="px-3 py-1.5 text-sm bg-gray-100 hover:bg-gray-200 text-gray-700 rounded-md dark:bg-gray-700 dark:hover:bg-gray-600 dark:text-gray-200">
            Cancel
          </button>
        </div>
      <% end %>
    </div>
  </div>
</div>
