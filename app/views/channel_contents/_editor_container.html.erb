<%= form_with model: @channel_content, url: channel_content_path(@channel, @channel_content), method: :patch, data: { controller: "content-editor", content_builder_target: "form" } do |f| %>
  <% if local_assigns[:error] %>
    <div class="mb-4 p-3 bg-red-50 dark:bg-red-900/20 border border-red-200 dark:border-red-800 rounded-md">
      <p class="text-sm text-red-700 dark:text-red-300"><%= error %></p>
    </div>
  <% end %>

  <div class="mb-4">
    <%= f.label :title, class: "block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1" %>
    <%= f.text_field :title, placeholder: "Optional title", class: "block w-full rounded-md border-gray-300 dark:border-gray-600 dark:bg-gray-700 dark:text-white shadow-sm focus:border-purple-500 focus:ring-purple-500 sm:text-sm" %>
  </div>

  <div data-controller="markdown-editor" data-markdown-editor-placeholder-value="Type your content here, or generate it with AI...">
    <%= f.text_area :content,
        placeholder: "Content will appear here after AI generation, or start writing...",
        class: "block w-full rounded-md border-gray-300 dark:border-gray-600 dark:bg-gray-700 dark:text-white shadow-sm focus:border-purple-500 focus:ring-purple-500 sm:text-sm font-mono",
        rows: 20,
        data: { markdown_editor_target: "textarea", content_editor_target: "textarea" } %>
  </div>

  <div class="mt-4 flex justify-end">
    <%= f.submit "Save Draft", class: "px-4 py-2 border border-transparent rounded-md shadow-sm text-sm font-medium text-white bg-blue-600 hover:bg-blue-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-blue-500 cursor-pointer", data: { content_editor_target: "saveBtn" } %>
  </div>
<% end %>
