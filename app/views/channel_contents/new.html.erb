<div class="space-y-6">
  <div class="flex items-center justify-between">
    <div>
      <div class="flex items-center gap-3">
        <%= link_to channel_path(@channel), class: "text-gray-400 hover:text-gray-500" do %>
          <svg class="h-6 w-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18"/>
          </svg>
        <% end %>
        <h1 class="text-2xl font-bold text-gray-900 dark:text-white">New Content</h1>
      </div>
      <p class="mt-1 text-sm text-gray-500 dark:text-gray-400">
        <%= @channel.name %> &middot; Create new content from <%= @selected_events.size %> selected events
      </p>
    </div>
  </div>

  <% if @selected_events.empty? %>
    <div class="bg-yellow-50 dark:bg-yellow-900/20 border border-yellow-200 dark:border-yellow-800 rounded-lg p-4">
      <p class="text-sm text-yellow-800 dark:text-yellow-200">
        No events selected. Please go back to the channel and select some events first.
      </p>
      <%= link_to "← Back to Channel", channel_path(@channel), class: "mt-2 inline-block text-sm text-yellow-700 dark:text-yellow-300 underline" %>
    </div>
  <% else %>
    <div class="bg-white dark:bg-gray-800 shadow rounded-lg p-6">
      <%= form_with model: @channel_content, url: channel_contents_path(@channel), method: :post, data: { turbo: false } do |f| %>
        <%= hidden_field_tag :event_ids, @selected_events.map(&:id).to_json %>

        <div class="space-y-6">
          <div>
            <%= f.label :title, class: "block text-sm font-medium text-gray-700 dark:text-gray-300" %>
            <%= f.text_field :title, placeholder: "Optional title for this content", class: "mt-1 block w-full rounded-md border-gray-300 dark:border-gray-600 dark:bg-gray-700 dark:text-white shadow-sm focus:border-purple-500 focus:ring-purple-500 sm:text-sm" %>
          </div>

          <div>
            <%= f.label :generation_prompt, "Theme / Direction (Optional)", class: "block text-sm font-medium text-gray-700 dark:text-gray-300" %>
            <%= f.text_area :generation_prompt,
                placeholder: "E.g., 'This issue will be mesh-network themed, weave the mesh-network themes into the text', 'Focus on the privacy aspects', 'Make it casual and fun'...",
                rows: 2,
                class: "mt-1 block w-full rounded-md border-gray-300 dark:border-gray-600 dark:bg-gray-700 dark:text-white shadow-sm focus:border-purple-500 focus:ring-purple-500 sm:text-sm" %>
            <p class="mt-1 text-xs text-gray-500 dark:text-gray-400">Optional guidance for the AI when generating content.</p>
          </div>

          <div>
            <p class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-2">Selected Source Events (<%= @selected_events.size %>)</p>
            <div class="space-y-2 max-h-64 overflow-y-auto border border-gray-200 dark:border-gray-700 rounded-md p-3">
              <% @selected_events.each do |event| %>
                <div class="text-sm bg-gray-50 dark:bg-gray-900 rounded p-2">
                  <p class="font-medium text-gray-900 dark:text-white"><%= event.source.name %></p>
                  <p class="text-gray-600 dark:text-gray-400"><%= event.content.truncate(200) %></p>
                </div>
              <% end %>
            </div>
          </div>

          <div class="flex justify-end gap-3">
            <%= link_to "Cancel", channel_path(@channel), class: "px-4 py-2 border border-gray-300 dark:border-gray-600 rounded-md shadow-sm text-sm font-medium text-gray-700 dark:text-gray-200 bg-white dark:bg-gray-800 hover:bg-gray-50 dark:hover:bg-gray-700" %>
            <%= f.submit "Create Draft & Open Editor", class: "px-4 py-2 border border-transparent rounded-md shadow-sm text-sm font-medium text-white bg-purple-600 hover:bg-purple-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-purple-500 cursor-pointer" %>
          </div>
        </div>
      <% end %>
    </div>
  <% end %>
</div>
