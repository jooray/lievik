<%= tag.div id: dom_id(job), class: "bg-white dark:bg-gray-800 rounded-lg p-3 shadow-sm" do %>
  <div class="flex items-center justify-between mb-2">
    <span class="text-sm text-gray-700 dark:text-gray-300"><%= job.message %></span>
    <div class="flex items-center gap-2">
      <span class="text-xs text-gray-500 dark:text-gray-400"><%= job.progress_percentage || 0 %>%</span>
      <%= button_to cancel_activity_log_path(job), method: :post, class: "inline-flex items-center justify-center w-5 h-5 text-gray-400 hover:text-red-600 dark:hover:text-red-400 hover:bg-red-50 dark:hover:bg-red-900/30 rounded transition-colors", title: "Cancel job", data: { turbo_confirm: "Cancel this job?" } do %>
        <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/>
        </svg>
      <% end %>
    </div>
  </div>
  <div class="w-full bg-gray-200 dark:bg-gray-700 rounded-full h-1.5">
    <div class="bg-purple-600 h-1.5 rounded-full transition-all duration-300" style="width: <%= job.progress_percentage || 5 %>%"></div>
  </div>
<% end %>
