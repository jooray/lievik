<div id="api-tokens" class="border-t border-gray-200 dark:border-gray-700 pt-6 mt-6">
  <div class="mb-4">
    <h2 class="text-lg font-medium text-gray-900 dark:text-white">API Tokens</h2>
    <p class="mt-1 text-sm text-gray-500 dark:text-gray-400">
      Tokens grant programmatic access to Lievik via the MCP endpoint at <code class="text-xs">/mcp</code>.
      Each token authenticates as you. Use one token per agent so you can revoke them independently.
    </p>
  </div>

  <% if flash[:plain_token].present? %>
    <div class="mb-4 p-4 bg-yellow-50 dark:bg-yellow-900/20 border border-yellow-300 dark:border-yellow-800 rounded-md">
      <p class="text-sm font-medium text-yellow-900 dark:text-yellow-100 mb-2">
        Token <strong><%= flash[:plain_token_name] %></strong> created. Copy it now — it will not be shown again.
      </p>
      <div class="flex items-center gap-2">
        <input type="text" readonly value="<%= flash[:plain_token] %>"
               aria-label="Your new API token"
               class="flex-1 font-mono text-xs px-2 py-1.5 rounded border border-yellow-300 dark:border-yellow-700 bg-white dark:bg-gray-900 text-gray-900 dark:text-gray-100"
               data-controller="clipboard"
               data-action="click->clipboard#selectAll" />
        <button type="button"
                data-controller="clipboard"
                data-clipboard-text-value="<%= flash[:plain_token] %>"
                data-action="click->clipboard#copy"
                class="px-3 py-1.5 text-xs font-medium rounded border border-yellow-300 dark:border-yellow-700 bg-white dark:bg-gray-900 text-gray-700 dark:text-gray-200 hover:bg-yellow-100 dark:hover:bg-yellow-900/40">
          Copy
        </button>
      </div>
    </div>
  <% end %>

  <div class="mb-6 p-4 bg-gray-50 dark:bg-gray-800 rounded-lg">
    <%= form_with url: api_tokens_path, method: :post, data: { turbo: false }, class: "flex items-end gap-3" do %>
      <div class="flex-1">
        <label for="api_token_name" class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">Token name</label>
        <%= text_field_tag :name, "", id: "api_token_name", placeholder: "e.g. marketing-agent",
            class: "block w-full rounded-md border-gray-300 dark:border-gray-600 dark:bg-gray-700 dark:text-white shadow-sm focus:border-purple-500 focus:ring-purple-500 sm:text-sm" %>
      </div>
      <button type="submit" class="inline-flex items-center px-4 py-2 border border-transparent text-sm font-medium rounded-md text-white bg-purple-600 hover:bg-purple-700">
        Generate token
      </button>
    <% end %>
  </div>

  <% tokens = current_user.api_tokens.order(created_at: :desc) %>
  <% if tokens.any? %>
    <div class="overflow-hidden border border-gray-200 dark:border-gray-700 rounded-lg">
      <table class="min-w-full divide-y divide-gray-200 dark:divide-gray-700 text-sm">
        <thead class="bg-gray-50 dark:bg-gray-800">
          <tr>
            <th class="px-4 py-2 text-left font-medium text-gray-700 dark:text-gray-300">Name</th>
            <th class="px-4 py-2 text-left font-medium text-gray-700 dark:text-gray-300">Created</th>
            <th class="px-4 py-2 text-left font-medium text-gray-700 dark:text-gray-300">Last used</th>
            <th class="px-4 py-2"></th>
          </tr>
        </thead>
        <tbody class="bg-white dark:bg-gray-900 divide-y divide-gray-200 dark:divide-gray-800">
          <% tokens.each do |token| %>
            <tr>
              <td class="px-4 py-2 text-gray-900 dark:text-gray-100"><%= token.name %></td>
              <td class="px-4 py-2 text-gray-500 dark:text-gray-400"><%= format_datetime(token.created_at) %></td>
              <td class="px-4 py-2 text-gray-500 dark:text-gray-400">
                <%= token.last_used_at ? "#{time_ago_in_words(token.last_used_at)} ago" : "Never" %>
              </td>
              <td class="px-4 py-2 text-right">
                <%= button_to "Revoke", api_token_path(token), method: :delete,
                    data: { turbo_confirm: "Revoke this token? Anything using it will lose access." },
                    class: "text-sm text-red-600 dark:text-red-400 hover:text-red-800 dark:hover:text-red-300" %>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  <% else %>
    <p class="text-sm text-gray-500 dark:text-gray-400">No tokens yet.</p>
  <% end %>
</div>
