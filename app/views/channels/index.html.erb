<div class="space-y-6">
  <div class="flex items-center justify-between">
    <div>
      <h1 class="text-2xl font-bold text-gray-900 dark:text-white">Channels</h1>
      <p class="mt-1 text-sm text-gray-500 dark:text-gray-400">
        Marketing outputs for curated content
      </p>
    </div>
    <div class="flex items-center gap-2">
      <%= link_to channel_ai_chat_path, class: "inline-flex items-center px-3 py-2 border border-purple-300 dark:border-purple-600 text-sm font-medium rounded-md text-purple-700 dark:text-purple-300 bg-white dark:bg-gray-800 hover:bg-purple-50 dark:hover:bg-purple-900/20" do %>
        <svg class="h-4 w-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547A3.374 3.374 0 0014 18.469V19a2 2 0 11-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z"/>
        </svg>
        Create with AI
      <% end %>
      <%= link_to new_channel_path, class: "inline-flex items-center px-3 py-2 border border-transparent text-sm font-medium rounded-md shadow-sm text-white bg-purple-600 hover:bg-purple-700" do %>
        <svg class="h-4 w-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"/>
        </svg>
        Create Channel
      <% end %>
    </div>
  </div>

  <% if @channels.empty? %>
    <div class="text-center py-12 bg-white dark:bg-gray-800 rounded-lg shadow">
      <svg class="mx-auto h-12 w-12 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 20l4-16m2 16l4-16M6 9h14M4 15h14"/>
      </svg>
      <h3 class="mt-2 text-sm font-medium text-gray-900 dark:text-white">No channels</h3>
      <p class="mt-1 text-sm text-gray-500 dark:text-gray-400">Create a channel for each marketing output.</p>
      <div class="mt-6">
        <%= link_to new_channel_path, class: "inline-flex items-center px-4 py-2 border border-transparent text-sm font-medium rounded-md shadow-sm text-white bg-purple-600 hover:bg-purple-700" do %>
          Create Channel
        <% end %>
      </div>
    </div>
  <% else %>
    <div class="grid grid-cols-1 gap-6 sm:grid-cols-2 lg:grid-cols-3">
      <% @channels.each do |channel| %>
        <div class="bg-white dark:bg-gray-800 shadow rounded-lg overflow-hidden hover:shadow-lg transition-shadow">
          <%= link_to channel, class: "block p-6" do %>
            <div class="flex items-center justify-between mb-4">
              <h3 class="text-lg font-medium text-gray-900 dark:text-white truncate">
                <%= channel.name %>
              </h3>
              <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-gray-100 dark:bg-gray-700 text-gray-800 dark:text-gray-200">
                <%= channel.language.upcase %>
              </span>
            </div>
            <% if channel.description.present? %>
              <p class="text-sm text-gray-500 dark:text-gray-400 line-clamp-2">
                <%= channel.description %>
              </p>
            <% end %>
            <div class="mt-4 flex items-center justify-between text-sm">
              <span class="text-gray-500 dark:text-gray-400">
                <%= @pending_event_counts.fetch(channel.id, 0) %> pending
              </span>
              <span class="text-purple-600 dark:text-purple-400">
                View &rarr;
              </span>
            </div>
          <% end %>
        </div>
      <% end %>
    </div>
  <% end %>
</div>
