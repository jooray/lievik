<!DOCTYPE html>
<html class="h-full">
  <head>
    <title><%= content_for(:title) || "Lievik" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="application-name" content="Lievik">
    <meta name="mobile-web-app-capable" content="yes">
    <meta name="color-scheme" content="light dark">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%# Apply the per-device theme before first paint to avoid a flash of the
        wrong mode. Mirrors app/javascript/controllers/theme_controller.js. %>
    <script>
      (function() {
        try {
          var t = localStorage.getItem("theme") || "system";
          var dark = t === "dark" ||
            (t === "system" && window.matchMedia("(prefers-color-scheme: dark)").matches);
          document.documentElement.classList.toggle("dark", dark);
        } catch (e) { /* private mode / no storage */ }
      })();
    </script>

    <%= yield :head %>

    <link rel="icon" href="/icon.png" type="image/png">
    <link rel="icon" href="/icon.svg" type="image/svg+xml">
    <link rel="apple-touch-icon" href="/icon.png">

    <%# Installable PWA (manifest-only — no service worker). %>
    <link rel="manifest" href="/manifest">
    <meta name="theme-color" content="#6d4bc3">

    <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>
    <%= stylesheet_link_tag "easymde", "data-turbo-track": "reload" %>
    <%= javascript_include_tag "application", "data-turbo-track": "reload", type: "module" %>
  </head>

  <body class="h-full bg-gray-50 dark:bg-gray-900 text-gray-900 dark:text-gray-100">
    <% if user_signed_in? %>
      <%= render "layouts/navigation" %>
    <% end %>

    <main class="<%= user_signed_in? ? 'lg:pl-64' : '' %>">
      <div class="<%= user_signed_in? ? 'px-4 py-8 sm:px-6 lg:px-8' : '' %>">
        <% if flash[:notice] %>
          <div class="mb-4 rounded-md bg-green-50 dark:bg-green-900 p-4">
            <p class="text-sm text-green-700 dark:text-green-200"><%= flash[:notice] %></p>
          </div>
        <% end %>

        <% if flash[:alert] %>
          <div class="mb-4 rounded-md bg-red-50 dark:bg-red-900 p-4">
            <p class="text-sm text-red-700 dark:text-red-200"><%= flash[:alert] %></p>
          </div>
        <% end %>

        <%= yield %>
      </div>
    </main>
  </body>
</html>
