<!DOCTYPE html>
<html class="h-full">
  <head>
    <title><%= content_for(:title) || "Lievik" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="application-name" content="Lievik">
    <meta name="mobile-web-app-capable" content="yes">
    <meta name="color-scheme" content="light dark">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%# Apply the per-device theme before first paint to avoid a flash of the
        wrong mode. Mirrors app/javascript/controllers/theme_controller.js.
        `data-theme-mode` also drives which toggle icon is painted (see the
        .theme-icon rules), so the icon is right before Stimulus connects. %>
    <%# nonce: true — the app's CSP is `script-src 'self'`, so a bare inline
        <script> would be blocked and the theme would flash on every load. %>
    <%= javascript_tag nonce: true do %>
      (function() {
        try {
          var t = localStorage.getItem("theme");
          if (t !== "light" && t !== "dark" && t !== "system") { t = "system"; }
          var dark = t === "dark" ||
            (t === "system" && window.matchMedia("(prefers-color-scheme: dark)").matches);
          document.documentElement.classList.toggle("dark", dark);
          document.documentElement.setAttribute("data-theme-mode", t);
        } catch (e) { /* private mode / no storage */ }
      })();
    <% end %>

    <%= yield :head %>

    <link rel="icon" href="/icon.png" type="image/png">
    <link rel="icon" href="/icon.svg" type="image/svg+xml">
    <link rel="apple-touch-icon" href="/icon.png">

    <%# Installable PWA. The service worker caches only digest-stamped assets;
        app freshness is handled by the version poller on <body>. %>
    <link rel="manifest" href="/manifest">
    <meta name="theme-color" content="#6d4bc3">

    <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>
<%# The EasyMDE stylesheet is render-blocking and only needed on the ~4 pages
    with a markdown editor, so those pages pull it in via content_for :head. %>
    <%= javascript_include_tag "application", "data-turbo-track": "reload", type: "module" %>
  </head>

  <body class="h-full bg-gray-50 dark:bg-gray-900 text-gray-900 dark:text-gray-100"
        data-controller="app-version"
        data-app-version-current-value="<%= Lievik::BUILD_VERSION %>"
        data-app-version-url-value="<%= app_version_path %>">
    <% if user_signed_in? %>
      <%= render "layouts/navigation" %>
    <% end %>

    <main class="<%= user_signed_in? ? 'lg:pl-64' : '' %>">
      <div class="<%= user_signed_in? ? 'px-4 py-8 sm:px-6 lg:px-8' : '' %>">
        <% if flash[:notice].present? %>
          <%= render "layouts/flash", kind: :notice, message: flash[:notice] %>
        <% end %>

        <% if flash[:alert].present? %>
          <%= render "layouts/flash", kind: :alert, message: flash[:alert] %>
        <% end %>

        <%= yield %>
      </div>
    </main>
  </body>
</html>
