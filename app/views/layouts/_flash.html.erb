<%# Flash message. Success and failure differ by icon and a leading word, not
    by colour alone, so the distinction survives colour-blindness and greyscale. %>
<% success = kind.to_s == "notice" %>
<div data-controller="flash"
     role="<%= success ? "status" : "alert" %>"
     class="mb-4 rounded-md border p-4 <%= success ? "bg-green-50 dark:bg-green-900/30 border-green-200 dark:border-green-800" : "bg-red-50 dark:bg-red-900/30 border-red-200 dark:border-red-800" %>">
  <div class="flex items-start gap-3">
    <% if success %>
      <svg class="h-5 w-5 flex-shrink-0 text-green-600 dark:text-green-400" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/>
      </svg>
    <% else %>
      <svg class="h-5 w-5 flex-shrink-0 text-red-600 dark:text-red-400" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
      </svg>
    <% end %>
    <p class="flex-1 text-sm <%= success ? "text-green-800 dark:text-green-200" : "text-red-800 dark:text-red-200" %>">
      <span class="font-semibold"><%= success ? "Success:" : "Problem:" %></span>
      <%= message %>
    </p>
    <button type="button"
            data-action="click->flash#dismiss"
            aria-label="Dismiss this message"
            class="flex-shrink-0 rounded p-1 <%= success ? "text-green-600 dark:text-green-400 hover:bg-green-100 dark:hover:bg-green-800/50" : "text-red-600 dark:text-red-400 hover:bg-red-100 dark:hover:bg-red-800/50" %>">
      <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/>
      </svg>
    </button>
  </div>
</div>
